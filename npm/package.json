{
  "name": "geolibre-wasm",
  "type": "module",
  "version": "0.4.3",
  "description": "Pure-Rust geospatial toolkit (whitebox_next_gen) compiled to WebAssembly (WASI) for GeoLibre's in-browser tool execution",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/opengeos/geolibre-rust"
  },
  "homepage": "https://github.com/opengeos/geolibre-rust",
  "keywords": ["geospatial", "wasm", "wasi", "gis", "geotiff", "lidar", "geolibre", "whitebox"],
  "main": "geolibre_wasm.js",
  "types": "geolibre_wasm.d.ts",
  "sideEffects": ["./snippets/*"],
  "files": [
    "geolibre_wasm.js",
    "geolibre_wasm_bg.wasm",
    "geolibre_wasm.d.ts",
    "geolibre_wasm_bg.wasm.d.ts",
    "geolibre-cli.wasm",
    "tools.mjs",
    "tools.d.ts",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./geolibre_wasm.d.ts",
      "default": "./geolibre_wasm.js"
    },
    "./tools": {
      "types": "./tools.d.ts",
      "default": "./tools.mjs"
    }
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.2"
  }
}
